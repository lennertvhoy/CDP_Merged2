# Local-only Tracardi helper configuration.
# Copy values into an untracked env file if you still need this format.

TRACARDI_API_URL=http://your-tracardi-host:8686
TRACARDI_GUI_URL=http://your-tracardi-host:8787
TRACARDI_USERNAME=your-tracardi-username
TRACARDI_PASSWORD=<redacted>
TRACARDI_TOKEN=<redacted>
TRACARDI_SOURCE_ID=kbo-source
TRACARDI_PUBLIC_IP=your-tracardi-ip
RESEND_API_KEY=<redacted>
RESEND_FROM_EMAIL=onboarding@example.com
