.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# OS
.DS_Store
Thumbs.db

# Docs and notebooks
docs/
notebooks/
*.md
!README.md
!chainlit.md
data/
KboOpenData_*.zip
*.zip
infra/
*.tfvars
*.tfvars.json
.azure-config/
