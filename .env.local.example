# Local-only overrides for offline development.
# Copy to `.env.local`, fill in your own keys, and keep the real file untracked.

# Use plain OpenAI first. This is the lowest-friction path for local work.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-key

# Optional: if Kimi exposes an OpenAI-compatible API, uncomment these and use
# your Kimi key plus the provider's OpenAI-compatible base URL.
# OPENAI_API_KEY=your-kimi-key
# OPENAI_BASE_URL=https://your-kimi-compatible-endpoint/v1
# LLM_MODEL=your-kimi-model-name

# Local query plane
DATABASE_URL=postgresql://cdpadmin:cdpadmin123@localhost:5432/cdp?sslmode=disable

# Local Tracardi stack
TRACARDI_API_URL=http://localhost:8686
TRACARDI_USERNAME=admin
TRACARDI_PASSWORD=admin
TRACARDI_SOURCE_ID=kbo-source

# Local app defaults
CHAINLIT_AUTH_SECRET=dev-local-secret-change-me-32chars-min
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000

# Optional local-only password auth for authenticated thread/history checks.
# Any non-empty username can sign in with this shared password.
CHAINLIT_DEV_AUTH_ENABLED=false
CHAINLIT_DEV_AUTH_PASSWORD=
