# ==========================================
# CDP_Merged - Environment Configuration
# Merges CDPT (Tracardi working) + CDP (multi-LLM, UI patterns)
# ==========================================

# ==========================================
# LLM Provider Configuration
# Supported: ollama, openai, azure_openai, mock
# ==========================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# OpenAI Settings (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here

# Ollama Settings (for local development)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Azure OpenAI Settings (required if LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-01

# ==========================================
# Tracardi CDP Configuration
# ==========================================
TRACARDI_API_URL=http://localhost:8686
TRACARDI_API_KEY=tracardi-secret-key
TRACARDI_SOURCE_ID=kbo-source
TRACARDI_USERNAME=admin
TRACARDI_PASSWORD=<redacted>

# ==========================================
# Flexmail Integration
# ==========================================
FLEXMAIL_ENABLED=false
FLEXMAIL_API_URL=http://localhost:8080/flexmail
FLEXMAIL_ACCOUNT_ID=your-account-id
FLEXMAIL_API_TOKEN=your-api-token
FLEXMAIL_SOURCE_ID=0
FLEXMAIL_WEBHOOK_SECRET=webhook-shared-secret

# ==========================================
# Elasticsearch
# ==========================================
ELASTICSEARCH_URL=http://localhost:9200

# ==========================================
# Application Settings
# ==========================================
LOG_LEVEL=INFO
DEBUG=false
CHAINLIT_PORT=8000

# Feature Flags
ENABLE_QUERY_VALIDATION=true
ENABLE_GDPR_COMPLIANCE=true
