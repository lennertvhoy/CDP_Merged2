# Local-only database and messaging configuration.
# Copy to `.env.database`, fill values from your secret store, and keep the real file untracked.

[database]
host = your-postgres-host
port = 5432
database = your-database-name
username = your-username
password = <redacted>
ssl_mode = require

[connection_string]
url = postgresql://your-username:<redacted>@your-postgres-host:5432/your-database-name?sslmode=require

[azure]
resource_group = your-resource-group
server_name = your-server-name
location = your-region
sku = your-sku
tier = your-tier
version = 15
storage_gb = 32

[eventhub]
namespace = your-eventhub-namespace
eventhub_name = your-eventhub-name
connection_string = Endpoint=sb://your-eventhub-namespace.servicebus.windows.net/;SharedAccessKeyName=your-key-name;SharedAccessKey=<redacted>

[notes]
# Retrieve real values from the approved secret source.
# Do not commit the populated `.env.database`.
