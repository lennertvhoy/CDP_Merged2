# ==========================================
# CDP_Merged - Environment Configuration
# Merges CDPT (Tracardi working) + CDP (multi-LLM, UI patterns)
# ==========================================

# ==========================================
# LLM Provider Configuration (REQUIRED)
# Supported: ollama, openai, azure_openai, mock
# ==========================================

# Provider selection - determines which LLM backend to use
# DEFAULT: azure_openai (uses Azure OpenAI GPT-5 deployment)
# Use openai for direct OpenAI API access (requires OPENAI_API_KEY)
LLM_PROVIDER=azure_openai
LLM_MODEL=gpt-5

# --- OpenAI Settings (required if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: for OpenAI-compatible APIs

# --- Ollama Settings (for local development) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Azure OpenAI Settings (required if LLM_PROVIDER=azure_openai) ---
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://aoai-cdpmerged-fast.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5
AZURE_OPENAI_DEPLOYMENT=gpt-5  # Legacy alias, same as above
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_API_KEY_SECRET_NAME=azure-openai-key  # For Key Vault integration

# ==========================================
# Tracardi CDP Configuration (OPTIONAL)
# ==========================================
# Tracardi is now an OPTIONAL activation adapter, not a core dependency.
# Core CDP functionality works without Tracardi using PostgreSQL + Operator Shell.
# Enable only if you need Tracardi-specific workflow/automation features.
# Architecture decision: 2026-03-14 - Tracardi demoted from core to optional

# Enable Tracardi integration
ENABLE_TRACARDI=false

# Tracardi API endpoint - only used if ENABLE_TRACARDI=true
# Example values:
#   local Docker: http://localhost:8686
#   remote deployment: http://your-tracardi-host:8686
TRACARDI_API_URL=http://your-tracardi-host:8686

# Tracardi authentication credentials (only needed if ENABLE_TRACARDI=true)
# IMPORTANT: Username depends on your deployment
TRACARDI_USERNAME=your-tracardi-username
TRACARDI_PASSWORD=your-tracardi-password
TRACARDI_SOURCE_ID=kbo-source

# ==========================================
# PostgreSQL Query Plane (REQUIRED for chatbot search)
# ==========================================

# The deployed chatbot uses PostgreSQL as the authoritative backend for search,
# counts, and analytics. In containers, provide DATABASE_URL explicitly.
DATABASE_URL=postgresql://your-user:your-password@your-postgres-host:5432/your-database-name?sslmode=require

# ==========================================
# MySQL Database Configuration (REQUIRED for Docker)
# ==========================================

# MySQL credentials for Docker Compose
# These are used by the MySQL service and Tracardi API
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=tracardi
MYSQL_USER=tracardi
MYSQL_PASSWORD=changeme

# ==========================================
# Flexmail Integration (OPTIONAL)
# ==========================================

# Enable Flexmail email marketing integration
FLEXMAIL_ENABLED=false
FLEXMAIL_API_URL=https://api.flexmail.be
FLEXMAIL_ACCOUNT_ID=your-account-id
FLEXMAIL_API_TOKEN=your-api-token
FLEXMAIL_SOURCE_ID=0
FLEXMAIL_WEBHOOK_SECRET=webhook-shared-secret

# ==========================================
# Resend Integration (OPTIONAL)
# Developer-friendly email API
# ==========================================

# Resend API key for sending transactional and bulk emails
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=onboarding@example.com

# ==========================================
# Elasticsearch (OPTIONAL)
# Used directly only for advanced queries
# Tracardi handles most ES operations internally
# ==========================================

ELASTICSEARCH_URL=http://localhost:9200

# ==========================================
# Redis Configuration (OPTIONAL)
# Required for session persistence across restarts
# ==========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# Azure AI Search Configuration (OPTIONAL)
# Feature-flagged retrieval backend
# ==========================================

# Enable Azure AI Search as primary retrieval backend
ENABLE_AZURE_SEARCH_RETRIEVAL=false

# Run Azure Search in parallel for comparison
ENABLE_AZURE_SEARCH_SHADOW_MODE=false

# Require citations in grounded responses
ENABLE_CITATION_REQUIRED=false

# Azure AI Search connection settings
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key
AZURE_SEARCH_API_KEY_SECRET_NAME=azure-search-key
AZURE_SEARCH_INDEX_NAME=cdp-index
AZURE_SEARCH_API_VERSION=2023-11-01
AZURE_SEARCH_TOP_K=20
AZURE_SEARCH_TIMEOUT_SECONDS=10.0

# Field mappings for Azure Search index
AZURE_SEARCH_ID_FIELD=id
AZURE_SEARCH_TITLE_FIELD=name
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_URL_FIELD=source_url

# ==========================================
# Azure Authentication Hardening (OPTIONAL)
# For Managed Identity / Key Vault integration
# ==========================================

# Use DefaultAzureCredential for Azure services
AZURE_AUTH_USE_DEFAULT_CREDENTIAL=true

# Allow explicit API key fallback
AZURE_AUTH_ALLOW_KEY_FALLBACK=true

# Strict mode: fail if not using MI/KV
AZURE_AUTH_STRICT_MI_KV_ONLY=false

# Key Vault URL for secret resolution
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net

# ==========================================
# Application Settings
# ==========================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode (more verbose output)
DEBUG=false

# Port for Chainlit UI (Azure Container Apps typically uses 8000)
CHAINLIT_PORT=8000
CHAINLIT_HOST=0.0.0.0

# Optional local-only password auth for authenticated history verification.
# When enabled, any non-empty username can sign in with the shared password below.
CHAINLIT_DEV_AUTH_ENABLED=false
CHAINLIT_DEV_AUTH_PASSWORD=

# ==========================================
# Microsoft Entra ID (Azure AD) OAuth - Work Account Authentication
# ==========================================
# Enable Microsoft work account login for colleague-facing rollout
CHAINLIT_ENABLE_AZURE_AD=false
# Your Azure AD Tenant ID (from Azure Portal > Azure Active Directory > Properties)
AZURE_AD_TENANT_ID=
# Your Azure AD Application (Client) ID (from App Registration > Overview)
AZURE_AD_CLIENT_ID=
# Your Azure AD Client Secret (from App Registration > Certificates & secrets)
AZURE_AD_CLIENT_SECRET=
# Redirect URI (must match app registration exactly)
AZURE_AD_REDIRECT_URI=http://localhost:8000/auth/oauth/azure-ad/callback

# ==========================================
# Web Search Policy
# ==========================================
# Options: disabled, restricted (admin-controlled), opt-in, default-on
WEB_SEARCH_POLICY=disabled
# Comma-separated list of allowed domains for web search (when policy=restricted)
WEB_SEARCH_ALLOWED_DOMAINS=microsoft.com,docs.microsoft.com,github.com,stackoverflow.com
# Patterns to block (PII protection) - comma-separated regex patterns  
WEB_SEARCH_BLOCKED_PATTERNS=\b\d{10}\b,\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b
# Enable audit logging for web search queries
WEB_SEARCH_AUDIT_LOG=true

# ==========================================
# Feature Flags
# ==========================================

# Enable query validation and critic layer
ENABLE_QUERY_VALIDATION=true

# Enable GDPR compliance checks
ENABLE_GDPR_COMPLIANCE=true

# ==========================================
# Event Hub Configuration (OPTIONAL)
# For event streaming architecture
# ==========================================

EVENTHUB_NAMESPACE=your-eventhub-namespace
EVENTHUB_NAME=cdp-events
EVENTHUB_CONNECTION_STRING=Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=...

# ==========================================
# Application Insights (OPTIONAL)
# For Azure monitoring and distributed tracing
# ==========================================

APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
APPLICATIONINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key

# ==========================================
# Local Development Settings
# ==========================================

# Enable hot reload in development
CHAINLIT_DEBUG=false

# Path to data files for KBO ingestion
KBO_DATA_PATH=./data/kbo

# ==========================================
# Security Settings
# ==========================================

# Max query length to prevent abuse
MAX_QUERY_LENGTH=1000

# Rate limiting: requests per minute
RATE_LIMIT_REQUESTS_PER_MINUTE=20

# ==========================================
# Testing Configuration
# ==========================================

# Set to 'true' to run integration tests
INTEGRATION_TESTS=false

# Test database URL (for isolated testing)
TEST_DATABASE_URL=sqlite:///./test.db
